datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client"
    previewFeatures = ["typedSql"]
    output   = ".generated"
}

enum Type {
    CREDIT
    DEBIT
}

model ledger_transactions {
    id         String     @id @default(uuid())
    user_id    String
    type       Type
    amount     Int
    created_at DateTime   @default(now())
    purchases  purchases?

    @@index([user_id], name: "idx_ledger_user_id")
    @@index([user_id, created_at], name: "idx_ledger_user_id_created_at")
}

model purchases {
    id             String              @id @default(uuid())
    transaction_id String              @unique
    transaction    ledger_transactions @relation(fields: [transaction_id], references: [id])
    item_id        String
    item_price     Int
    created_at     DateTime            @default(now())
}
