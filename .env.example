# Example environment variables (do NOT store real secrets here)
# Copy to .env and fill with real values: cp .env.example .env

# Postgres connection string (required)
# Example format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Optional shadow DB used by Prisma migrate (recommended for safe migrations)
# Example format: postgresql://user:password@host:5432/shadow_db
DATABASE_SHADOW_URL=

# App settings
PORT=3000
NODE_ENV=development

# Optional: add these only if you integrate Supabase client in the backend
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Railway API key used by CI/CD to trigger deployments.
# Set RAILWAY_API_KEY as a secret in GitHub.
# RAILWAY_API_KEY=
# GITHUB_TOKEN=